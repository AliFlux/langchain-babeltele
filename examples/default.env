# Copy this file to `.env` (or edit it in place) and fill in your details.
# The examples load `default.env` first, then `.env` if present (which overrides).

# Which chat model drives compression. Format: "<provider>:<model>".
# Resolved via langchain's init_chat_model, so any supported provider works.
#   anthropic:claude-sonnet-4-6
#   openai:gpt-4o-mini
#   google_genai:gemini-2.0-flash
BABELTELE_MODEL=anthropic:claude-sonnet-4-6

# Embedding model used by the long-term memory example. Same "<provider>:<model>"
# format, resolved via langchain's init_embeddings. Note: Anthropic has no
# embeddings endpoint, so this usually points at a different provider than above.
#   openai:text-embedding-3-small
#   google_genai:text-embedding-004
BABELTELE_EMBEDDINGS=openai:text-embedding-3-small

# Provider API keys. Only the one matching BABELTELE_MODEL is needed.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional: custom OpenAI-compatible endpoint (LiteLLM, vLLM, OpenRouter, a local
# server, etc.). langchain reads OPENAI_API_BASE (note: the raw openai SDK uses
# OPENAI_BASE_URL instead). Leave blank to use OpenAI's default endpoint.
# OPENAI_API_BASE=https://your-proxy.example.com/v1
